# Sift — environment variables. Copy to .env and fill in values.

# --- LLM (Ollama) ---
MODEL_PLANNING=qwen2.5:7b
MODEL_SYNTHESIS=qwen2.5:7b
MODEL_ROUTING=qwen2.5:7b

# --- Embeddings (needed for RAGAS eval judge) ---
# Run: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# --- Auth ---
# CHANGE THIS in any non-demo deployment: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# --- Observability (Langfuse) — disabled by default ---
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# --- API ---
# API_HOST=0.0.0.0
# API_PORT=8001
